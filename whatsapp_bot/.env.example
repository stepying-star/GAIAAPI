# ── WhatsApp Cloud API ──────────────────────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_TOKEN=your_permanent_access_token_here
WA_VERIFY_TOKEN=soonhoe_verify_2026
WA_APP_SECRET=your_app_secret_here

# ── Anthropic Claude ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server ───────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
DEBUG=false

# ── Database ─────────────────────────────────────────────
DB_PATH=/home/ubuntu/whatsapp_bot/data/bot.db

# ── Admin Dashboard ──────────────────────────────────────
ADMIN_TOKEN=change_this_to_a_strong_random_string

# ── Staff Notification ───────────────────────────────────
# Your WhatsApp number (with country code, no +). Leave empty to disable.
NOTIFY_WHATSAPP=6512345678

# ── Session ──────────────────────────────────────────────
SESSION_TIMEOUT_MIN=60
